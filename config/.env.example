# ============================================================
# AI Trader - 환경변수 (.env)
# ============================================================
# 이 파일을 .env로 복사한 후 실제 값을 입력하세요.
# .env 파일은 절대 git에 포함하지 마세요.

# 한국투자증권 KIS OpenAPI — 모의투자
KIS_VIRTUAL_APP_KEY=your_virtual_app_key
KIS_VIRTUAL_APP_SECRET=your_virtual_app_secret
KIS_VIRTUAL_ACCOUNT_NO=your_virtual_account      # 모의투자 계좌번호 (예: 50123456-01)

# 한국투자증권 KIS OpenAPI — 실전투자
KIS_REAL_APP_KEY=your_real_app_key
KIS_REAL_APP_SECRET=your_real_app_secret
KIS_REAL_ACCOUNT_NO=your_real_account             # 실전 계좌번호 (예: 12345678-01)

# 공통
KIS_ACCOUNT_PRODUCT_CODE=01

# Claude API (Anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# DART OpenAPI (공시 정보)
DART_API_KEY=your_dart_api_key_here
